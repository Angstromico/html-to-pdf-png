{
  "name": "html-to-pdf-png",
  "version": "2.1.0",
  "description": "Convert any HTML file to PDF and/or high-quality PNG images using Playwright (TypeScript)",
  "main": "build/html-to-pdf.js",
  "scripts": {
    "build": "tsc",
    "pdf": "npm run build && node build/html-to-pdf.js",
    "png": "npm run build && node build/html-to-png.js",
    "pdf:dev": "npx ts-node src/html-to-pdf.ts",
    "png:dev": "npx ts-node src/html-to-png.ts",
    "md-to-html": "npm run build && node build/md-to-html.js",
    "md-to-html:dev": "npx ts-node src/md-to-html.ts",
    "png-to-pdf": "npm run build && node build/png-to-pdf.js",
    "png-to-pdf:dev": "npx ts-node src/png-to-pdf.ts",
    "batch:png": "npm run build && node build/batch-html-to-png.js",
    "batch:png:dev": "npx ts-node src/batch-html-to-png.ts",
    "example:pdf": "npm run build && node build/html-to-pdf.js ./examples/example.html",
    "example:png": "npm run build && node build/html-to-png.js ./examples/example.html",
    "example:all": "npm run build && node build/html-to-pdf.js ./examples/example.html && node build/html-to-png.js ./examples/example.html",
    "install:browsers": "npx playwright install chromium"
  },
  "keywords": [
    "html",
    "pdf",
    "png",
    "converter",
    "playwright",
    "mermaid",
    "screenshot",
    "cli",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "markdown-it": "^14.1.1",
    "markdown-it-mermaid": "^0.2.5",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
